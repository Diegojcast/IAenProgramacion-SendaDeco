# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
# Get a free PostgreSQL database at https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"
# Your app's public URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth provider ────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Admin access ────────────────────────────────────────────────────────────
# Comma-separated list of Google account emails allowed into /admin
ADMIN_EMAILS="diegojcast@gmail.com"

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Get an API key at https://resend.com
RESEND_API_KEY="re_your_api_key_here"
# Sender address — must be a verified domain in Resend
EMAIL_FROM="Senda Deco <noreply@sendadeco.com>"
